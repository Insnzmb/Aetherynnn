# LLM backend (provider-agnostic)
# Default is local-first (Ollama), but you can switch to any OpenAI-compatible API by setting:
#  LLM_PROVIDER=openai_compat
#  LLM_BASE_URL=<your api base>
#  LLM_API_KEY=<your key>
#  LLM_MODEL=<your model>
LLM_PROVIDER=ollama

# Ollama (local or remote)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=auto

# Retrieval settings (keeps context small so RAM/VRAM usage is steadier)
RETRIEVE_K=6
RETRIEVED_CHUNK_MAX_CHARS=2600

# Server
PORT=8080

# Action roll mode
# prompt: require a roll every action (default)
# auto: server auto-rolls and resolves immediately
ACTION_ROLL_MODE=prompt

# Output caps (increase if choices are missing due to truncation)
RULES_MAX_TOKENS=600
NARRATION_MAX_TOKENS=2200

# AI Pipeline (reduce model workload)
AI_PIPELINE=unified
UNIFIED_MAX_TOKENS=3600
UNIFIED_MAX_TOKENS_KICKOFF=3200
KICKOFF_UNIFIED_LITE=1
# Kickoff overrides (power-user)
#  - KICKOFF_NO_TIMEOUT=1 disables AbortController timeouts for kickoff_unified.
#  - KICKOFF_NO_MAXTOKENS=1 removes the kickoff token cap (Ollama uses num_predict=-1).
KICKOFF_NO_TIMEOUT=1
KICKOFF_NO_MAXTOKENS=1
CANON_DUMP_MAX_LINES_KICKOFF=120
CANON_DUMP_MAX_CHARS_KICKOFF=6000
RETRIEVE_K_UNIFIED=4

# Bookscribe mode (reduce extra model call)
BOOKSCRIBE_MODE=local

# Book scribe (used to convert player actions into novel-style lines)
OLLAMA_BOOK_MODEL=auto
BOOK_MAX_TOKENS=120
BOOK_TAIL_CHARS=7000

# Narrator provider: "ollama" or "grok"
NARRATOR_PROVIDER=ollama

# xAI Grok (optional narrator). Set XAI_API_KEY and choose a model if you want NARRATOR_PROVIDER=grok.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai
GROK_MODEL=grok-4-1-fast-reasoning
GROK_TEMPERATURE=0.7

# Book structure (minimums)
MIN_BEATS_PER_SCENE=10
MIN_SCENES_PER_SESSION=10


# Scope Lockdown (keep the model inside AETHERYN)
SCOPE_LOCKDOWN=on
SCOPE_STRICTNESS=2
META_PREFIX=/


# Ollama tuning (applies to rules + narration + book helpers unless overridden)
OLLAMA_NUM_CTX=8192
OLLAMA_REPEAT_LAST_N=256
OLLAMA_REPEAT_PENALTY=1.15
OLLAMA_TOP_K=40
OLLAMA_TOP_P=0.9

# Optional per-role temperatures
RULES_TEMPERATURE=0.1
NARRATION_TEMPERATURE=0.7
BOOKSCRIBE_TEMPERATURE=0.6
BOOK_TITLE_TEMPERATURE=0.7
POV_MAX_TOKENS=1800
ROUND_NARR_MAX_TOKENS=1600
# Timeouts (ms)
# If you see "LLM request timed out after ...", raise these.
LLM_TIMEOUT_MS=120000
LLM_TIMEOUT_MS_INTAKE=240000
LLM_TIMEOUT_MS_KICKOFF=45000

# UI safety net (ms). If <= 0, disables auto-clear of "AI is thinking".
AI_WAIT_MAX_MS=0

# Intake retrieval (smaller = faster; intake answers already contain the needed info)
RETRIEVE_K_INTAKE=3

# Role-specific Ollama context (smaller ctx = faster on many local models)
# Keep NARRATOR/UNIFIED higher if you want longer prose continuity.
OLLAMA_NUM_CTX_RULES=4096
OLLAMA_NUM_CTX_BOOK=4096
OLLAMA_NUM_CTX_TITLE=2048
# OLLAMA_NUM_CTX_NARRATOR=8192
# OLLAMA_NUM_CTX_UNIFIED=8192

# Asset currency (used for code-authoritative purchases)
ASSET_CURRENCY=Coin_Aurum


# DEV BUILD (AI trace)
# Use RUN_WINDOWS_DEV.bat / RUN_MAC_LINUX_DEV.sh or set DEV_BUILD=on
DEV_BUILD=off
DEV_LOG_MAX=900