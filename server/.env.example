# LLM BACKEND (provider-agnostic)
# The runtime can use *any* LLM that can do chat-style prompts.
#
# Supported providers out of the box:
# - ollama        (local)       -> uses OLLAMA_URL + auto-installed model selection
# - openai_compat (hosted/self) -> uses /v1/chat/completions (many APIs follow this)
#
# If you want the simplest setup:
# - Local (Ollama): leave defaults and run Ollama.
# - Hosted/OpenAI-style: set LLM_PROVIDER=openai_compat and fill LLM_BASE_URL/LLM_API_KEY/LLM_MODEL.

LLM_PROVIDER=ollama
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
LLM_ALLOW_BLANK_KEY=off
LLM_TIMEOUT_MS=120000
# NEW (recommended): idle timeout while streaming (resets as the model outputs).
# If your model is slow but still producing tokens, this prevents false timeouts.
# If unset, the server uses LLM_TIMEOUT_MS.
LLM_IDLE_TIMEOUT_MS=
# Optional: intake is often the slowest/first call (model warm-up + big prompt).
# If set, overrides timeout ONLY for intake processing.
LLM_TIMEOUT_MS_INTAKE=240000
LLM_TIMEOUT_MS_KICKOFF=45000

# UI safety net (ms). If <= 0, disables auto-clear of "AI is thinking".
# Host can still use the in-game Cancel AI button.
AI_WAIT_MAX_MS=0

# Optional: only affects the non-critical /api/tags ping used for auto-model selection.
OLLAMA_TAGS_TIMEOUT_MS=5000

# Optional per-role overrides (leave blank to inherit LLM_PROVIDER/LLM_MODEL)
LLM_PROVIDER_RULES=
LLM_MODEL_RULES=
LLM_PROVIDER_NARRATOR=
LLM_MODEL_NARRATOR=
LLM_PROVIDER_BOOK=
LLM_MODEL_BOOK=
LLM_PROVIDER_SUMMARY=
LLM_MODEL_SUMMARY=
LLM_PROVIDER_TITLE=
LLM_MODEL_TITLE=

# Ollama (local or remote) — used when LLM_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=auto
# Tip: if you see timeouts, set this to a smaller model (example: llama3.1:8b or gemma3:4b).

# Retrieval settings (keeps context small so RAM/VRAM usage is steadier)
RETRIEVE_K=6
RETRIEVED_CHUNK_MAX_CHARS=2600

# Server
PORT=8080

# Output caps (increase if choices are missing due to truncation)
RULES_MAX_TOKENS=600
NARRATION_MAX_TOKENS=2200

# AI Pipeline (reduce model workload)
AI_PIPELINE=unified
UNIFIED_MAX_TOKENS=3600
UNIFIED_MAX_TOKENS_KICKOFF=3200
KICKOFF_UNIFIED_LITE=1
# Kickoff overrides (power-user)
#  - KICKOFF_NO_TIMEOUT=1 disables AbortController timeouts for kickoff_unified.
#  - KICKOFF_NO_MAXTOKENS=1 removes the kickoff token cap (Ollama uses num_predict=-1).
KICKOFF_NO_TIMEOUT=0
KICKOFF_NO_MAXTOKENS=0
CANON_DUMP_MAX_LINES_KICKOFF=120
CANON_DUMP_MAX_CHARS_KICKOFF=6000
RETRIEVE_K_UNIFIED=4

# Bookscribe mode (reduce extra model call)
BOOKSCRIBE_MODE=local

# Book scribe (used to convert player actions into novel-style lines)
OLLAMA_BOOK_MODEL=auto
BOOK_MAX_TOKENS=120
BOOK_TAIL_CHARS=7000

# Legacy narrator selector (still supported): "ollama" or "grok".
# Prefer LLM_PROVIDER_NARRATOR for new setups.
NARRATOR_PROVIDER=ollama

# xAI Grok (optional narrator). Set XAI_API_KEY and choose a model if you want NARRATOR_PROVIDER=grok.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai
GROK_MODEL=grok-4-1-fast-reasoning
GROK_TEMPERATURE=0.7

# Book structure (minimums)
MIN_BEATS_PER_SCENE=10
MIN_SCENES_PER_SESSION=10


# Scope Lockdown (keep the model inside AETHERYN)
SCOPE_LOCKDOWN=on
SCOPE_STRICTNESS=2
META_PREFIX=/


# Ollama tuning (applies to rules + narration + book helpers unless overridden)
OLLAMA_NUM_CTX=8192
OLLAMA_REPEAT_LAST_N=256
OLLAMA_REPEAT_PENALTY=1.15
OLLAMA_TOP_K=40
OLLAMA_TOP_P=0.9

# Optional per-role temperatures
RULES_TEMPERATURE=0.1
NARRATION_TEMPERATURE=0.7
BOOKSCRIBE_TEMPERATURE=0.6
BOOK_TITLE_TEMPERATURE=0.7
POV_MAX_TOKENS=1800
ROUND_NARR_MAX_TOKENS=1600

# Hallucination / Drift Firewall (server-side)
# If ON, the server will reject and regenerate model outputs that:
# - lack sources[] grounding in retrieved canon chunks
# - invent new place/faction/institution names (unless explicitly framed as rumor)
# - imply mechanical gains without ops[]
HALLUCINATION_GUARD=on
HALLUCINATION_AUDIT=on
HALLUCINATION_MAX_ATTEMPTS=3

# Narrator retrieval (split pipeline only)
RETRIEVE_K_NARRATOR=3